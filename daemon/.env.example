# Secrets for obsidian-remind. Copy to .env (gitignored). Used by the daemon
# and by docker compose (which reads this file automatically). These override
# the matching fields in config.json.

# CouchDB password (url/database/username usually live in config.json).
COUCHDB_PASSWORD=

# Pushover application API token/key and your user/group key.
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Optional: path to the config file (default: ./config.json).
# Not used by docker compose (the container sets CONFIG to /config/config.json).
# CONFIG=/etc/obsidian-remind/config.json
