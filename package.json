		"datepicker"
	],
	"author": "netdex",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "^6.36.0",
		"@types/node": "^20.11.30",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.20.2",
		"obsidian": "latest",
		"typescript": "^5.4.3"
	}
}
